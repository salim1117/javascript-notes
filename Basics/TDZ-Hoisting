
-// Hoisting is JavaScript's behavior of moving
// declarations to the top of their scope before execution.



// JavaScript reads the whole file first
// Then executes it 


// var
console.log(a); // undefined
var a = 10;

// let
// console.log(b); // ReferenceError
let b = 20;

// const
// console.log(c); // ReferenceError
const c = 30;

// Function Declaration
hello(); // Works

function hello() {
    console.log("Hello");
}

// Function Expression
// greet(); // TypeError

var greet = function() {
    console.log("Hi");
};

// Arrow Function
// test(); // ReferenceError

let test = () => {
    console.log("Arrow");
};